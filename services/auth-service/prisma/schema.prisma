datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/@prisma/client-auth"
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String
  role         String   // STUDENT, COLLEGE_TNP_OFFICER, RECRUITER, ADMIN
  collegeId    String   // Tenant boundary (e.g. "MIT", "Stanford")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
